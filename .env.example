# PostgreSQL bootstrap
POSTGRES_ADMIN_USER=platform_admin
POSTGRES_ADMIN_PASSWORD=replace_with_strong_password
POSTGRES_HOST_PORT=5433

# Application database
APP_DB_NAME=b2b_onboarding
APP_DB_USER=b2b_app
APP_DB_PASSWORD=replace_with_strong_password

# n8n database
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=replace_with_strong_password

# Redis
REDIS_PASSWORD=replace_with_strong_password

# n8n runtime
N8N_ENCRYPTION_KEY=replace_with_random_string
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678/
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Warsaw
TZ=Europe/Warsaw
N8N_WORKER_CONCURRENCY=5
N8N_VERSION=2.30.8

# WF02 client-data request runtime
CLIENT_DATA_FORM_BASE_URL=http://localhost:5678/form/replace_with_wf03_form_path
CLIENT_DATA_FORM_TOKEN_TTL_HOURS=72
CLIENT_DATA_TOKEN_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key
CLIENT_DATA_TOKEN_ENCRYPTION_KEY_ID=local-v1
WF02_OPERATION_LEASE_SECONDS=300
WF02_OPERATION_MAX_ATTEMPTS=5
CLIENT_DATA_REQUEST_SENDER_NAME=B2B Onboarding
CLIENT_DATA_SUPPORT_CONTACT=support@example.com

# Mock Provisioning API
MOCK_PROVISIONING_API_PORT=3001
